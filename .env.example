# Database
# PostgreSQL محلي:
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/baytalmosawer?schema=public"

# SQLite للتطوير بدون PostgreSQL:
# DATABASE_URL="file:./prisma/dev.db"

# NextAuth v5
AUTH_SECRET="change-me-to-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-secret"

# Platform
NEXT_PUBLIC_PLATFORM_NAME="بيت المصور"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_TAGLINE="منصة تعليمية للمصورين العرب"

# Email
EMAIL_FROM="noreply@baytalmosawer.com"
# EMAIL_MOCK=true  # الافتراضي عند غياب SMTP
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASS="your-password"
# SMTP_FROM="noreply@baytalmosawer.com"

# Payments
PAYMENT_PROVIDER="mock"
# Stripe (when PAYMENT_PROVIDER=stripe)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_CURRENCY="sar"

# Railway / Production
# NODE_ENV=production
# بعد النشر حدّث الرابطين برابط Railway الفعلي:
# NEXTAUTH_URL="https://your-app.up.railway.app"
# NEXT_PUBLIC_SITE_URL="https://your-app.up.railway.app"
