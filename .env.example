# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/baytalmosawer?schema=public"

# NextAuth v5
AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# Platform
NEXT_PUBLIC_PLATFORM_NAME="بيت المصور"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_TAGLINE="منصة تعليمية للمصورين العرب"

# Email — Brevo API preferred on Railway (SMTP may hang)
EMAIL_FROM="noreply@baytalmosawer.com"
EMAIL_MOCK=true
# BREVO_API_KEY="xkeysib-..."  # preferred — same key as Brevo SMTP/API
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT=587
# SMTP_USER="your-smtp-user"
# SMTP_PASS="your-smtp-key"
# SMTP_FROM="noreply@baytalmosawer.com"

# Payments — mock for dev; stripe for production
PAYMENT_PROVIDER="mock"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_CURRENCY="sar"

# Object storage (Cloudflare R2 / AWS S3 compatible)
# S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
# S3_PUBLIC_URL="https://pub-xxx.r2.dev"
# S3_BUCKET="baytalmosawer-media"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_REGION="auto"

# Rate limiting (optional — Upstash Redis REST)
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# Monitoring (optional webhook for errors)
# MONITORING_WEBHOOK_URL="https://hooks.slack.com/..."
# HEALTH_DETAILED=true

# Production (Railway)
# NODE_ENV=production
# NEXTAUTH_URL="https://your-app.up.railway.app"
# NEXT_PUBLIC_SITE_URL="https://your-app.up.railway.app"
# PAYMENT_PROVIDER=stripe
# EMAIL_MOCK=false
# After deploy — rotate seed passwords once:
# CONFIRM_ROTATE=1 npx tsx scripts/rotate-seed-passwords.ts

# Custom domain (optional)
# NEXTAUTH_URL="https://baytalmosawer.com"
# NEXT_PUBLIC_SITE_URL="https://baytalmosawer.com"
